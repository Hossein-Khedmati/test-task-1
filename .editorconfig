
root = true

# Unix-style newlines with a newline ending every file
[*]
end_of_line = lf
insert_final_newline = true
charset = utf-8

# Indentation
indent_style = space
indent_size = 2
trim_trailing_whitespace = true

# JSON and YAML files (used a lot in Next.js config, CI, etc.)
[*.{json,yml,yaml}]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false  # To avoid issues in some JSON files

# Markdown
[*.md]
trim_trailing_whitespace = false  # Keeps formatting in code blocks

# TypeScript, JavaScript, JSX, TSX
[*.{ts,tsx,js,jsx}]
indent_style = space
indent_size = 2

# CSS, SCSS, and other styles
[*.{css,scss,less}]
indent_style = space
indent_size = 2
